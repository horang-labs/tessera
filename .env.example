# App Settings
NODE_ENV=development
PORT=3000

# Paths (auto-created on first run, do not modify unless necessary)
USERS_FILE_PATH=~/.tessera/users.json
AUTH_KEYS_DIR=~/.tessera/auth
SESSIONS_METADATA_DIR=~/.tessera/sessions

# JWT Settings (optional, auto-generated if not set)
# JWT_PRIVATE_KEY_PATH=~/.tessera/auth/private.pem
# JWT_PUBLIC_KEY_PATH=~/.tessera/auth/public.pem

# Claude Code CLI Settings (optional)
# CLAUDE_CLI_PATH=claude  # Use custom path if 'claude' is not in PATH

# Logging (optional)
# LOG_LEVEL=info  # debug, info, warn, error

# Voice Input STT (optional - enables voice input feature)
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash  # default: gemini-2.5-flash
